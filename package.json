{
  "name": "asm-agent",
  "version": "0.0.4",
  "private": true,
  "description": "Local ASM project generation agent for company chip platforms.",
  "main": "dist-main/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "spec:compile": "tsx scripts/compileSpec.ts",
    "asm:validate": "tsx scripts/validateAsm.ts",
    "package:win": "npm run build && electron-builder --win nsis",
    "release:win": "npm run build && electron-builder --win nsis",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "jsdom": "^26.0.0",
    "mammoth": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "wait-on": "^8.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
